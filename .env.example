# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentportal

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=                        # 64 char random hex
JWT_REFRESH_SECRET=                # 64 char random hex (must differ from JWT_SECRET)

# Key Vault (AES-256-GCM)
VAULT_SECRET=                      # 32 byte hex string

# Email (Brevo — free tier: 300 emails/day)
BREVO_API_KEY=                     # Brevo API key (xkeysib-...)
BREVO_SENDER_NAME=AgentFlow        # Display name in "From" field
BREVO_SENDER_EMAIL=                # Verified sender email in Brevo (e.g. noreply@yourdomain.com)

# OpenRouter
OPENROUTER_PLATFORM_KEY=           # Platform's own OpenRouter key (for Free plan users)

# OpenAI (embeddings only)
OPENAI_API_KEY=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=agent-memory

# Payment Provider Toggle
PAYMENT_PROVIDER_DEFAULT=razorpay   # 'stripe' | 'razorpay' — runtime override via admin API

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BYOK=price_xxx

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=plan_xxx          # Created in Razorpay Dashboard > Subscriptions > Plans
RAZORPAY_PLAN_BYOK=plan_xxx

# Admin
ADMIN_EMAILS=admin@example.com      # Comma-separated emails authorized to toggle payment provider

# App
APP_URL=http://localhost:3000
PORT=3001
NODE_ENV=development

# Sentry
SENTRY_DSN=
